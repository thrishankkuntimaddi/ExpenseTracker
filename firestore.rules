rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns their top-level doc + ALL subcollections under it
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /transactions/{txnId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /income/{incId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /external_transactions/{extId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
